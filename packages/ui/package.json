{
  "name": "@trail-pm/ui",
  "version": "0.2.3",
  "description": "Trail local roadmap UI (React + Hono API)",
  "type": "module",
  "files": [
    "dist",
    "dist-server",
    "bin"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "trail-ui": "./bin/trail-ui.js"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run build:client && npm run build:server",
    "build:client": "tsc -b && vite build",
    "build:server": "tsup",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "preserver": "node scripts/free-dev-ports.mjs && node scripts/ensure-dev-deps.mjs && npm run build:server",
    "predev:all": "node scripts/free-dev-ports.mjs && node scripts/ensure-dev-deps.mjs && npm run build:server",
    "dev:all": "concurrently -k -n api,vite -c blue,green \"npm run server\" \"node scripts/wait-for-api.mjs && npm run dev\"",
    "server": "npx tsx scripts/run-dev-server.mjs",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hono/node-server": "^1.14.1",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.14",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-select": "^2.1.14",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.2",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.6",
    "@tanstack/react-query": "^5.75.5",
    "@tanstack/react-virtual": "^3.13.2",
    "@tiptap/extension-link": "^3.23.5",
    "@tiptap/extension-placeholder": "^3.23.5",
    "@tiptap/pm": "^3.23.5",
    "@tiptap/react": "^3.23.5",
    "@tiptap/starter-kit": "^3.23.5",
    "@trail-pm/cli": "file:../cli",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.2.1",
    "hono": "^4.7.6",
    "lucide-react": "^0.475.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.5.1",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.2.0",
    "tailwindcss-animate": "^1.0.7",
    "tiptap-markdown": "^0.9.0"
  },
  "optionalDependencies": {
    "@tailwindcss/oxide-linux-x64-gnu": "^4.2.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.4",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "tailwindcss": "^4.1.4",
    "tsup": "^8.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.3.2"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joeydekruis/trail.git",
    "directory": "packages/ui"
  },
  "keywords": [
    "trail",
    "project-management",
    "kanban",
    "roadmap"
  ]
}
